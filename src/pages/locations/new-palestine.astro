---
// New Palestine, IN — coming-soon campus. All copy lives in src/data/locations.ts.
import BaseLayout from "../../layouts/BaseLayout.astro";
import ComingSoonLocation from "../../components/ComingSoonLocation.astro";
import { getLocation, locationJsonLd } from "../../data/locations";

const loc = getLocation("new-palestine");
---

<BaseLayout title={loc.metaTitle} description={loc.metaDescription}>
  <script
    type="application/ld+json"
    slot="head"
    is:inline
    set:html={JSON.stringify(locationJsonLd(loc))}
  />
  <ComingSoonLocation loc={loc} />
</BaseLayout>
