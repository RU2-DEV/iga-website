---
// Bargersville, IN — the flagship (first-to-open) campus page.
// NAP data, JSON-LD, and the programs section come from src/data/locations.ts;
// the photo / map / full-licensing sections below are unique to this page.
import BaseLayout from "../../layouts/BaseLayout.astro";
import LocationBreadcrumb from "../../components/LocationBreadcrumb.astro";
import LocationNapCard from "../../components/LocationNapCard.astro";
import LocationPrograms from "../../components/LocationPrograms.astro";
import { getLocation, locationJsonLd } from "../../data/locations";

const loc = getLocation("bargersville");
---

<BaseLayout title={loc.metaTitle} description={loc.metaDescription}>
  <script
    type="application/ld+json"
    slot="head"
    is:inline
    set:html={JSON.stringify(locationJsonLd(loc))}
  />

  <LocationBreadcrumb loc={loc} />

  <!-- ========== HERO ========== -->
  <section class="location-hero">
    <div class="container">
      <div class="location-hero-grid fade-in">
        <div class="location-hero-text">
          <div class="location-status status-open">
            <span class="status-dot" aria-hidden="true"></span>
            <span>{loc.statusLabel}</span>
          </div>
          <h1>{loc.heroHeading}</h1>
          <p class="location-hero-sub">{loc.heroSub}</p>
          <div class="location-hero-actions">
            <a href="/enroll" class="btn btn-green btn-lg">Schedule a Free Tour &rarr;</a>
            <a href="#nap" class="btn btn-outline-teal btn-lg">Get Directions</a>
          </div>
        </div>

        <LocationNapCard loc={loc} />
      </div>
    </div>
  </section>

  <!-- ========== ABOUT THIS LOCATION ========== -->
  <section class="section">
    <div class="container">
      <div class="location-about fade-in">
        <div class="location-about-text">
          <p class="eyebrow">About this campus</p>
          <h2>{loc.aboutHeading}</h2>
          <div class="content-placeholder content-placeholder--wide">
            <p class="content-placeholder-label">DRAFT &mdash; for client review</p>
            <p class="content-placeholder-hint">{loc.aboutHint}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PROGRAMS AT THIS LOCATION ========== -->
  <LocationPrograms loc={loc} />

  <!-- ========== PHOTOS ========== -->
  <section class="section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="eyebrow">A look inside</p>
        <h2>Our Bargersville campus.</h2>
        <p>Photography placeholders below. Real photos go in once construction wraps and licensing inspections complete.</p>
      </div>

      <div class="location-photos fade-in">
        <div class="placeholder-img" role="img" aria-label="Photo placeholder: exterior of Bargersville campus">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M8 22L24 10l16 12v18H8V22z" stroke="#2C6F95" stroke-width="2" fill="none"/>
            <rect x="20" y="30" width="8" height="10" stroke="#2C6F95" stroke-width="1.5" fill="none"/>
          </svg>
          <span class="placeholder-label">Exterior &middot; building front, signage, parking</span>
        </div>
        <div class="placeholder-img" role="img" aria-label="Photo placeholder: classroom interior">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="8" y="14" width="32" height="22" stroke="#2C6F95" stroke-width="2" fill="none"/>
            <circle cx="16" cy="25" r="3" stroke="#2C6F95" stroke-width="1.5" fill="none"/>
            <circle cx="28" cy="25" r="3" stroke="#2C6F95" stroke-width="1.5" fill="none"/>
          </svg>
          <span class="placeholder-label">Classroom &middot; preschool room, natural light, learning corners</span>
        </div>
        <div class="placeholder-img" role="img" aria-label="Photo placeholder: outdoor play area">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="14" cy="18" r="6" fill="#6CB43A" opacity="0.5"/>
            <circle cx="34" cy="20" r="8" fill="#6CB43A" opacity="0.5"/>
            <line x1="0" y1="36" x2="48" y2="36" stroke="#2C6F95" stroke-width="2"/>
          </svg>
          <span class="placeholder-label">Outdoor play &middot; fenced yard, age-appropriate equipment</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== MAP ========== -->
  <section class="section section-teal-bg">
    <div class="container">
      <div class="section-header fade-in">
        <p class="eyebrow">Find us</p>
        <h2>Located in Bargersville.</h2>
        <p>Easy access from Greenwood, Franklin, and the southside Indianapolis metro.</p>
      </div>

      <div class="location-map-placeholder fade-in" role="img" aria-label="Map placeholder for Bargersville campus location">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M24 6c-6 0-11 5-11 11 0 8 11 19 11 19s11-11 11-19c0-6-5-11-11-11z" stroke="#2C6F95" stroke-width="2" fill="none"/>
          <circle cx="24" cy="17" r="4" fill="#2C6F95"/>
        </svg>
        <p class="placeholder-label">Embedded Google Map goes here once address is finalized. Will use Google Maps Embed API with the verified GBP address.</p>
      </div>
    </div>
  </section>

  <!-- ========== LICENSING ========== -->
  <section class="section">
    <div class="container">
      <div class="section-header fade-in">
        <p class="eyebrow">Licensing &amp; credentials</p>
        <h2>Our Bargersville campus, by the paperwork.</h2>
      </div>

      <div class="credentials-block fade-in">
        <h3>State licensing</h3>
        <dl class="credentials-list">
          <div>
            <dt>License type</dt>
            <dd>Indiana Class 1 Licensed Childcare Center</dd>
          </div>
          <div>
            <dt>Licensing body</dt>
            <dd>Indiana Family &amp; Social Services Administration (FSSA), Bureau of Child Care</dd>
          </div>
          <div>
            <dt>License number</dt>
            <dd>Available upon request</dd>
          </div>
          <div>
            <dt>Licensed capacity</dt>
            <dd><span class="placeholder-inline">[CAPACITY TBD]</span> children</dd>
          </div>
          <div>
            <dt>Inspection record</dt>
            <dd>Available upon request</dd>
          </div>
        </dl>

        <h3>Staff at this campus</h3>
        <dl class="credentials-list">
          <div>
            <dt>Lead teachers</dt>
            <dd>Minimum Associate's degree in Early Childhood Education or related field</dd>
          </div>
          <div>
            <dt>Background checks</dt>
            <dd>100% of staff: FBI, Indiana state criminal history, sex offender registry, DCS</dd>
          </div>
          <div>
            <dt>CPR &amp; first aid</dt>
            <dd>100% certified, renewed annually</dd>
          </div>
          <div>
            <dt>Annual training</dt>
            <dd>Hours exceed Indiana FSSA minimums</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- ========== CTA BAND ========== -->
  <section class="cta-band section-dark">
    <div class="container">
      <div class="fade-in">
        <h2>See the Bargersville campus in person.</h2>
        <p>Tours take about 30 minutes. Meet the teachers, see the classrooms, and ask every question you have.</p>
        <a href="/enroll" class="btn btn-white btn-lg">Schedule a Free Tour</a>
      </div>
    </div>
  </section>
</BaseLayout>
