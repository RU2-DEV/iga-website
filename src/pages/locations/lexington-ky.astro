---
// Lexington, KY — coming-soon campus (first Kentucky location).
// All copy, including the KY licensing rows, lives in src/data/locations.ts.
import BaseLayout from "../../layouts/BaseLayout.astro";
import ComingSoonLocation from "../../components/ComingSoonLocation.astro";
import { getLocation, locationJsonLd } from "../../data/locations";

const loc = getLocation("lexington-ky");
---

<BaseLayout title={loc.metaTitle} description={loc.metaDescription}>
  <script
    type="application/ld+json"
    slot="head"
    is:inline
    set:html={JSON.stringify(locationJsonLd(loc))}
  />
  <ComingSoonLocation loc={loc} />
</BaseLayout>
