---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Childcare in Fishers, IN | Imagination Grove Academy" description="Imagination Grove Academy is coming soon to Fishers, IN. Safe, joyful childcare for children 6 weeks&ndash;5 years. Low ratios, degree-qualified teachers, state-licensed. Join the waitlist.">
  <script type="application/ld+json" slot="head" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "ChildCare",
    "name": "Imagination Grove Academy &mdash; Fishers",
    "url": "https://imaginationgroveacademy.com/locations/fishers/",
    "telephone": "[PHONE TBD]",
    "email": "team@imaginationgroveacademy.com",
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "[STREET TBD]",
      "addressLocality": "Fishers",
      "addressRegion": "IN",
      "postalCode": "[ZIP TBD]",
      "addressCountry": "US"
    },
    "areaServed": [
      { "@type": "City", "name": "Fishers" },
      { "@type": "City", "name": "Noblesville" },
      { "@type": "City", "name": "Carmel" }
    ],
    "parentOrganization": {
      "@type": "Organization",
      "name": "Imagination Grove Academy",
      "url": "https://imaginationgroveacademy.com"
    }
  }
  </script>

    <!-- ========== BREADCRUMB ========== -->
    <nav class="location-breadcrumb" aria-label="Breadcrumb">
      <div class="container">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/locations">Locations</a></li>
          <li aria-current="page">Fishers, IN</li>
        </ol>
      </div>
    </nav>

    <!-- ========== HERO ========== -->
    <section class="location-hero">
      <div class="container">
        <div class="location-hero-grid fade-in">
          <div class="location-hero-text">
            <div class="location-status status-soon">
              <span class="status-dot" aria-hidden="true"></span>
              <span>Coming soon</span>
            </div>
            <h1>Childcare in Fishers, IN.</h1>
            <p class="location-hero-sub">Imagination Grove Academy is coming to Fishers. Safe, joyful childcare for children 6 weeks&ndash;5 years &mdash; with low teacher-to-child ratios, degree-qualified teachers, and a curriculum that respects how young children actually learn. Join the waitlist to be first in line.</p>
            <div class="location-hero-actions">
              <a href="/enroll" class="btn btn-green btn-lg">Join the Waitlist &rarr;</a>
              <a href="/locations" class="btn btn-outline-teal btn-lg">See open locations</a>
            </div>
          </div>

          <aside class="location-nap-card" id="nap" aria-labelledby="nap-heading">
            <h2 id="nap-heading" class="nap-heading">Coming to Fishers</h2>

            <dl class="nap-list">
              <div>
                <dt>Address</dt>
                <dd>
                  <address>
                    <span class="placeholder-inline">[STREET TBD]</span><br>
                    Fishers, IN <span class="placeholder-inline">[ZIP]</span>
                  </address>
                </dd>
              </div>
              <div>
                <dt>Phone</dt>
                <dd><span class="placeholder-inline">[PHONE TBD]</span></dd>
              </div>
              <div>
                <dt>Email</dt>
                <dd><a href="mailto:fishers@imaginationgroveacademy.com">fishers@imaginationgroveacademy.com</a></dd>
              </div>
              <div>
                <dt>Hours</dt>
                <dd>Monday&ndash;Friday<br>6:30 AM &ndash; 6:00 PM</dd>
              </div>
              <div>
                <dt>Opening</dt>
                <dd><span class="placeholder-inline">[OPENING DATE TBD]</span></dd>
              </div>
            </dl>
          </aside>

        </div>
      </div>
    </section>

    <!-- ========== ABOUT THIS LOCATION ========== -->
    <section class="section">
      <div class="container">
        <div class="location-about fade-in">
          <div class="location-about-text">
            <p class="eyebrow">About this campus</p>
            <h2>An IGA campus is coming to Fishers.</h2>
            <div class="content-placeholder content-placeholder--wide">
              <p class="content-placeholder-label">DRAFT &mdash; for client review</p>
              <p class="content-placeholder-hint">Location-specific paragraph goes here once the Fishers building, neighborhood context, and opening timeline are finalized. Mention the area being served (Geist? Saxony? Hamilton County north?), what makes this campus distinct, and any partnerships or features unique to the Fishers location. This is what helps the page rank for "childcare Fishers Indiana" once live.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== PROGRAMS AT THIS LOCATION ========== -->
    <section class="section section-green-bg">
      <div class="container">
        <div class="section-header fade-in">
          <p class="eyebrow">When the Fishers campus opens</p>
          <h2>Programs for every age, 6 weeks through Pre-K.</h2>
          <p>Every IGA campus serves all four age groups. Class sizes are capped below state-mandated minimums in every program.</p>
        </div>

        <ul class="location-programs fade-in" aria-label="Programs offered at this location">
          <li>
            <h3>Infant Care</h3>
            <p class="age-meta">6 weeks &ndash; 12 months &middot; 1:4 ratio</p>
            <p>Calm, primary-caregiver-led infant care with parent-set feed and nap schedules.</p>
            <a href="/programs#infant" class="card-link">Learn about infant care &rarr;</a>
          </li>
          <li>
            <h3>Toddler Program</h3>
            <p class="age-meta">1 &ndash; 2 years &middot; 1:5 ratio</p>
            <p>Sensory play, language-rich rooms, and the gentle structure toddlers need.</p>
            <a href="/programs#toddler" class="card-link">Learn about toddler care &rarr;</a>
          </li>
          <li>
            <h3>Preschool</h3>
            <p class="age-meta">3 &ndash; 4 years &middot; 1:8 ratio</p>
            <p>Curiosity-led curriculum with foundational literacy, math, and independent learning.</p>
            <a href="/programs#preschool" class="card-link">Learn about preschool &rarr;</a>
          </li>
          <li>
            <h3>Pre-K</h3>
            <p class="age-meta">4 &ndash; 5 years &middot; 1:10 ratio</p>
            <p>Kindergarten-ready academic foundations with strong social-emotional growth.</p>
            <a href="/programs#pre-k" class="card-link">Learn about Pre-K &rarr;</a>
          </li>
        </ul>
      </div>
    </section>

    <!-- ========== WAITLIST CTA ========== -->
    <section class="section section-teal-bg">
      <div class="container">
        <div class="location-waitlist fade-in">
          <h2>Be first in line when Fishers opens.</h2>
          <p>The Fishers campus is opening soon. Join the waitlist and we'll reach out as soon as we have an opening date and tour availability.</p>
          <a href="/enroll" class="btn btn-green btn-lg">Join the Waitlist &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ========== LICENSING ========== -->
    <section class="section">
      <div class="container">
        <div class="section-header fade-in">
          <p class="eyebrow">Licensing &amp; credentials</p>
          <h2>Our Fishers campus, by the paperwork.</h2>
        </div>

        <div class="credentials-block fade-in">
          <h3>State licensing</h3>
          <dl class="credentials-list">
            <div>
              <dt>License type</dt>
              <dd>Indiana Class 1 Licensed Childcare Center (pending)</dd>
            </div>
            <div>
              <dt>Licensing body</dt>
              <dd>Indiana Family &amp; Social Services Administration (FSSA), Bureau of Child Care</dd>
            </div>
            <div>
              <dt>License number</dt>
              <dd><span class="placeholder-inline">[ISSUED AT OPENING]</span></dd>
            </div>
            <div>
              <dt>Licensed capacity</dt>
              <dd><span class="placeholder-inline">[CAPACITY TBD]</span> children</dd>
            </div>
          </dl>

          <h3>Staff at this campus</h3>
          <dl class="credentials-list">
            <div>
              <dt>Hiring</dt>
              <dd>Lead teachers and assistant teachers will be hired ahead of opening, with the same credentialing standards as all IGA campuses.</dd>
            </div>
            <div>
              <dt>Standards</dt>
              <dd>Lead teachers: minimum Associate's degree in ECE. 100% background-checked. CPR &amp; pediatric first aid required.</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <!-- ========== CTA BAND ========== -->
    <section class="cta-band section-dark">
      <div class="container">
        <div class="fade-in">
          <h2>While you wait, visit our Bargersville campus.</h2>
          <p>The same curriculum, the same standards, the same IGA. Touring Bargersville is the fastest way to see what we'll bring to Fishers.</p>
          <a href="/locations/bargersville" class="btn btn-white btn-lg">See the Bargersville campus</a>
        </div>
      </div>
    </section>
</BaseLayout>
