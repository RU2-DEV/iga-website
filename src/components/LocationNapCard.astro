---
// The NAP (name / address / phone) card on each location page.
// All values come from src/data/locations.ts — never hardcode NAP here.
// Placeholders render until real data is filled in on the location entry.
import type { Location } from "../data/locations";

interface Props {
  loc: Location;
}
const { loc } = Astro.props;
---

<aside class="location-nap-card" id="nap" aria-labelledby="nap-heading">
  <h2 id="nap-heading" class="nap-heading">{loc.napHeading}</h2>

  <dl class="nap-list">
    <div>
      <dt>Address</dt>
      <dd>
        <address>
          {loc.streetAddress
            ? <span>{loc.streetAddress}</span>
            : <span class="placeholder-inline">[STREET TBD]</span>}<br />
          {loc.cityState}{" "}
          {loc.postalCode
            ? <span>{loc.postalCode}</span>
            : <span class="placeholder-inline">[ZIP]</span>}
        </address>
      </dd>
    </div>
    <div>
      <dt>Phone</dt>
      <dd>
        {loc.telephone
          ? <a href={`tel:${loc.telephone.replace(/[^+\d]/g, "")}`}>{loc.telephone}</a>
          : <span class="placeholder-inline">[PHONE TBD]</span>}
      </dd>
    </div>
    <div>
      <dt>Email</dt>
      <dd><a href={`mailto:${loc.email}`}>{loc.email}</a></dd>
    </div>
    <div>
      <dt>Hours</dt>
      <dd>Monday–Friday<br />6:30 AM – 6:00 PM</dd>
    </div>
    <div>
      <dt>Opening</dt>
      <dd><span class="placeholder-inline">[OPENING DATE TBD]</span></dd>
    </div>
  </dl>
</aside>
